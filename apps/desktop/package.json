{
  "name": "@t3tools/desktop",
  "version": "0.0.15",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun run --parallel dev:bundle dev:backend dev:electron",
    "fix:sandbox": "node scripts/fix-linux-sandbox.mjs",
    "dev:bundle": "tsdown --config tsdown.config.mts --watch",
    "dev:backend": "bun run --cwd ../server dev:bundle",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "tsdown --config tsdown.config.mts",
    "start": "bun run scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "effect": "catalog:",
    "electron": "40.6.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "productName": "T3 Code (Alpha)"
}
